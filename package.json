{
  "name": "devvault-cred-manager",
  "displayName": "DevVault Credential Manager",
  "description": "Secure credential storage, right where you code.",
  "version": "0.1.1",
  "publisher": "AsyncOwl",
  "license": "MIT",
  "homepage": "https://asyncowl.com/dev-vault",
  "bugs": {
    "url": "https://github.com/sisodiakaran/dev-vault/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sisodiakaran/dev-vault"
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0B1220",
    "theme": "dark"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "password",
    "vault",
    "credentials",
    "security",
    "local",
    "devvault"
  ],
  "activationEvents": [
    "onView:devvault.vault",
    "onCommand:devvault.unlock",
    "onCommand:devvault.lock",
    "onCommand:devvault.add",
    "onCommand:devvault.fillForUrl",
    "onCommand:devvault.openInBrowser",
    "onCommand:devvault.generatePassword",
    "onCommand:devvault.changeMasterPassword",
    "onCommand:devvault.statusBar.select"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "icons": {
      "devvault-icon": {
        "description": "DevVault extension icon",
        "default": {
          "fontPath": "./media/devvault-icons.woff",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devvault",
          "title": "DevVault",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "devvault": [
        {
          "id": "devvault.vault",
          "name": "Vault",
          "icon": "media/activity-icon.svg",
          "visibility": "visible"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "devvault.vault",
        "contents": "Secure credential storage, right where you code.\n\n[Unlock Vault](command:devvault.unlock)\n\n[Generate Password](command:devvault.generatePassword)",
        "when": "!devvault.unlocked"
      },
      {
        "view": "devvault.vault",
        "contents": "No credentials yet.\n\n[Add Entry](command:devvault.add)",
        "when": "devvault.unlocked"
      }
    ],
    "commands": [
      {
        "command": "devvault.unlock",
        "title": "DevVault: Unlock Vault",
        "icon": "$(unlock)"
      },
      {
        "command": "devvault.lock",
        "title": "DevVault: Lock Vault",
        "icon": "$(lock)"
      },
      {
        "command": "devvault.add",
        "title": "DevVault: Add Entry",
        "icon": "$(add)"
      },
      {
        "command": "devvault.edit",
        "title": "DevVault: Edit Entry",
        "icon": "$(edit)"
      },
      {
        "command": "devvault.delete",
        "title": "DevVault: Delete Entry",
        "icon": "$(trash)"
      },
      {
        "command": "devvault.copyUsername",
        "title": "DevVault: Copy Username",
        "icon": "$(account)"
      },
      {
        "command": "devvault.copyPassword",
        "title": "DevVault: Copy Password",
        "icon": "$(key)"
      },
      {
        "command": "devvault.reveal",
        "title": "DevVault: Reveal Password",
        "icon": "$(eye)"
      },
      {
        "command": "devvault.fillForUrl",
        "title": "DevVault: Fill for URL…",
        "icon": "$(globe)"
      },
      {
        "command": "devvault.openInBrowser",
        "title": "DevVault: Open in Browser & Login",
        "icon": "$(link-external)"
      },
      {
        "command": "devvault.generatePassword",
        "title": "DevVault: Generate Password",
        "icon": "$(shield)"
      },
      {
        "command": "devvault.refresh",
        "title": "DevVault: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "devvault.changeMasterPassword",
        "title": "DevVault: Change Master Password"
      },
      {
        "command": "devvault.statusBar.select",
        "title": "DevVault: Select Status Bar Entry"
      },
      {
        "command": "devvault.statusBar.fillUsername",
        "title": "DevVault: Fill Username at Selection"
      },
      {
        "command": "devvault.statusBar.fillPassword",
        "title": "DevVault: Fill Password at Selection"
      },
      {
        "command": "devvault.statusBar.copyUsername",
        "title": "DevVault: Copy Username"
      },
      {
        "command": "devvault.statusBar.copyPassword",
        "title": "DevVault: Copy Password"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devvault.unlock",
          "when": "view == devvault.vault && !devvault.unlocked",
          "group": "navigation@1"
        },
        {
          "command": "devvault.lock",
          "when": "view == devvault.vault && devvault.unlocked",
          "group": "navigation@1"
        },
        {
          "command": "devvault.add",
          "when": "view == devvault.vault && devvault.unlocked",
          "group": "navigation@2"
        },
        {
          "command": "devvault.refresh",
          "when": "view == devvault.vault",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "devvault.copyUsername",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "inline@1"
        },
        {
          "command": "devvault.copyPassword",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "inline@2"
        },
        {
          "command": "devvault.openInBrowser",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "inline@3"
        },
        {
          "command": "devvault.openInBrowser",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "1_copy@0"
        },
        {
          "command": "devvault.copyUsername",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "1_copy@1"
        },
        {
          "command": "devvault.copyPassword",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "1_copy@2"
        },
        {
          "command": "devvault.reveal",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "1_copy@3"
        },
        {
          "command": "devvault.edit",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "2_edit@1"
        },
        {
          "command": "devvault.delete",
          "when": "view == devvault.vault && viewItem == vaultEntry",
          "group": "2_edit@2"
        }
      ],
      "commandPalette": [
        {
          "command": "devvault.edit",
          "when": "false"
        },
        {
          "command": "devvault.delete",
          "when": "false"
        },
        {
          "command": "devvault.copyUsername",
          "when": "false"
        },
        {
          "command": "devvault.copyPassword",
          "when": "false"
        },
        {
          "command": "devvault.reveal",
          "when": "false"
        },
        {
          "command": "devvault.refresh",
          "when": "false"
        },
        {
          "command": "devvault.statusBar.select",
          "when": "false"
        },
        {
          "command": "devvault.statusBar.fillUsername",
          "when": "false"
        },
        {
          "command": "devvault.statusBar.fillPassword",
          "when": "false"
        },
        {
          "command": "devvault.statusBar.copyUsername",
          "when": "false"
        },
        {
          "command": "devvault.statusBar.copyPassword",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devvault.fillForUrl",
        "key": "ctrl+shift+alt+f",
        "mac": "cmd+shift+alt+f",
        "when": "devvault.unlocked"
      },
      {
        "command": "devvault.lock",
        "key": "ctrl+shift+alt+l",
        "mac": "cmd+shift+alt+l",
        "when": "devvault.unlocked"
      }
    ],
    "configuration": {
      "title": "DevVault",
      "properties": {
        "devvault.clipboardClearSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 300,
          "description": "Seconds before the clipboard is cleared after copying a password or username."
        },
        "devvault.idleLockMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 240,
          "description": "Minutes of inactivity before the vault locks automatically. Set to 0 to disable."
        },
        "devvault.rememberUnlockHours": {
          "type": "number",
          "default": 24,
          "minimum": 0,
          "maximum": 168,
          "description": "Hours to remember the master password across restarts (stored in OS keychain / SecretStorage). Set to 0 to require unlock every time. Manual Lock clears the remembered session."
        },
        "devvault.passwordLength": {
          "type": "number",
          "default": 20,
          "minimum": 8,
          "maximum": 128,
          "description": "Default length for generated passwords."
        },
        "devvault.passwordIncludeSymbols": {
          "type": "boolean",
          "default": true,
          "description": "Include symbols when generating passwords."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "vsix": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies",
    "publish:openvsx": "ovsx publish --no-dependencies",
    "check-types": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "ovsx": "^1.0.2",
    "typescript": "^5.6.0"
  }
}
